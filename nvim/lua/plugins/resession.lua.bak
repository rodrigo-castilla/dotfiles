return {
  {
    "https://gitlab.com/itaranto/preview.nvim",
    version = "*",
    init = function()
      -- Esto asegura que Neovim reconozca el archivo (Ya lo tienes funcionando, pero lo dejamos por seguridad)
      vim.api.nvim_create_autocmd({ "BufRead", "BufNewFile" }, {
        pattern = { "*.puml", "*.plantuml" },
        callback = function() vim.bo.filetype = "plantuml" end,
      })
    end,
    opts = {
      render_on_write = true,
      previewers_by_ft = {
        plantuml = {
          name = "plantuml_png",
          renderer = {
            type = "command",
            opts = {
              -- EXPLICACIÓN PARA WSL:
              -- 1. Copiamos el temporal a uno con extensión .puml para que PlantUML no se queje.
              -- 2. Ejecutamos plantuml.
              -- 3. Usamos 'explorer.exe' (el de Windows) para abrir la imagen desde WSL.
              cmd = {
                "sh",
                "-c",
                'cp "$1" "$1.puml" && plantuml -tpng "$1.puml" && explorer.exe $(wslpath -w "$1.png")',
                "--",
                "$FILE",
              },
            },
          },
        },
      },
    },
  },
}
